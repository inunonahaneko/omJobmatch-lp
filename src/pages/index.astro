---
import "../styles/global.css";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@700;800&family=Noto+Sans+JP:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    >
    <title>omJob match | 候補者に合う求人を、もっと速く、もっと確かに。</title>
    <meta
      name="description"
      content="omJob matchは、CRMに蓄積された候補者・求人データを整理し、CAの求人提案業務を支援するAIエージェントです。"
    >
  </head>
  <body>
    <header class="site-header" data-header>
      <a class="logo-link" href="#top" aria-label="omJob match トップへ">
        <img src={`${basePath}assets/omjob-logo.png`} alt="omJob match" width="168" height="106">
      </a>
      <nav class="desktop-nav" aria-label="主要ナビゲーション">
        <a href="#problem">課題</a>
        <a href="#features">できること</a>
      </nav>
      <div class="header-actions">
        <a class="button button-download" href="#cta" data-intent-link="download">資料ダウンロード</a>
        <a class="button button-consult" href="#cta" data-intent-link="consult">相談してみる</a>
      </div>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" data-nav-toggle>
        <span></span>
        <span></span>
        <span></span>
      </button>
    </header>

    <nav class="mobile-nav" id="mobile-nav" aria-label="モバイルナビゲーション" data-mobile-nav>
      <a href="#problem">課題</a>
      <a href="#features">できること</a>
      <a href="#cta" data-intent-link="download">サービス資料をダウンロード</a>
      <a href="#cta" data-intent-link="consult">相談してみる</a>
    </nav>

    <main id="top">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">CAの求人提案業務を支援するAIエージェント</p>
          <h1>
            <span class="headline-line"><span>候補者に合う求人を、</span></span>
            <span class="headline-line"><span>もっと速く、</span></span>
            <span class="headline-line"><span>もっと確かに。</span></span>
          </h1>
          <p class="hero-lead">
            OmJob Matchは、CRMに蓄積された候補者情報・求人情報を整理し、CAが提案準備に迷わず、根拠ある求人提案に進める状態をつくるAIエージェントです。
          </p>
          <div class="hero-actions">
            <a class="button button-download" href="#cta" data-intent-link="download">資料ダウンロード</a>
            <a class="button button-demo" href="#top">60秒デモを見る</a>
          </div>
        </div>

        <div class="video-shell" aria-label="omJob match デモ動画プレースホルダー">
          <canvas class="hero-rive-face" width="640" height="640" data-rive-face aria-hidden="true"></canvas>
          <div class="hero-face-effect" aria-hidden="true">
            <svg viewBox="0 0 620 620">
              <defs>
                <radialGradient id="hero-face-gradient" cx="42%" cy="38%" r="68%">
                  <stop offset="0%" stop-color="#5c86ff" stop-opacity="0.18"></stop>
                  <stop offset="58%" stop-color="#0038e5" stop-opacity="0.11"></stop>
                  <stop offset="100%" stop-color="#0038e5" stop-opacity="0.04"></stop>
                </radialGradient>
              </defs>
              <circle class="face-fill" cx="310" cy="310" r="300"></circle>
              <circle class="face-spread" cx="310" cy="310" r="300"></circle>
              <path class="face-smile-line" d="M172 318c52 108 224 108 276 0"></path>
            </svg>
          </div>
          <div class="video-frame">
            <div class="product-mock">
              <div class="mock-topbar">
                <span></span>
                <span></span>
                <span></span>
                <strong>omJob match デモ</strong>
              </div>
              <div class="mock-body">
                <aside class="mock-sidebar">
                  <div class="mock-chip active">データ整理</div>
                  <div class="mock-chip">候補者要約</div>
                  <div class="mock-chip">求人比較</div>
                  <div class="mock-chip">提案理由</div>
                </aside>
                <div class="mock-flow">
                  <div class="mock-source candidate">
                    <span>CRM / CSV</span>
                    <strong>面談メモ・希望条件</strong>
                  </div>
                  <div class="mock-source job">
                    <span>求人データ</span>
                    <strong>要件・魅力・注意点</strong>
                  </div>
                  <div class="mock-arrow">整理</div>
                  <div class="mock-result">
                    <span>omJob match</span>
                    <strong>提案根拠を整理</strong>
                    <ul>
                      <li>候補者情報を要約</li>
                      <li>求人情報を比較</li>
                      <li>推薦理由を生成</li>
                    </ul>
                  </div>
                  <div class="mock-ready">
                    <span>提案準備</span>
                    <strong>CAがすぐ使える状態に</strong>
                  </div>
                </div>
              </div>
            </div>
            <button class="play-button" type="button" aria-label="デモ動画を再生" data-demo-button>
              <span></span>
            </button>
          </div>
          <p class="video-caption" data-demo-status>CRM/CSVデータを整理し、候補者情報・求人情報・提案理由をひとつの流れで確認できます。</p>
        </div>
      </section>

      <section class="section problem" id="problem" aria-labelledby="problem-title">
        <div class="section-heading">
          <p class="eyebrow">Problem</p>
          <h2 id="problem-title" class="reveal-heading">
            <span>
              <span class="title-line">求人提案の準備が、</span>
              <span class="title-line"><span class="heading-accent">CAの経験や記憶</span>に頼りきりになっていませんか？</span>
            </span>
          </h2>
        </div>
      </section>

      <section class="section features" id="features" aria-labelledby="features-title">
        <div class="section-heading">
          <p class="eyebrow">Features</p>
          <h2 id="features-title" class="reveal-heading">
            <span>求人提案に必要な情報を、<span class="heading-accent">提案に使える状態</span>へ。</span>
          </h2>
          <p>
            候補者情報・求人情報・面談メモ・CRM/CSVデータを整理し、CAが迷わず提案に進める状態をつくります。
          </p>
        </div>
        <div class="feature-showcase">
          <article class="feature-row">
            <div class="feature-copy">
              <h3>候補者情報を、<span>提案に使いやすく</span>整理</h3>
              <p>必要な情報をひと目で確認でき、候補者理解にかかる時間を減らします。</p>
            </div>
            <div class="screen-card" aria-label="候補者一覧・候補者詳細の画面イメージ">
              <div class="app-screen candidate-screen">
                <div class="screen-topbar"><strong>候補者</strong><span>検索</span><span>条件</span></div>
                <div class="screen-layout">
                  <aside>
                    <b>候補者一覧</b>
                    <p class="is-active">佐藤 亜美</p>
                    <p>田中 健太</p>
                    <p>山本 美咲</p>
                    <p>鈴木 亮</p>
                  </aside>
                  <section>
                    <div class="profile-head">
                      <div><strong>佐藤 亜美</strong><small>営業企画 / 年収500万円希望</small></div>
                      <span>提案準備中</span>
                    </div>
                    <div class="info-grid">
                      <div><b>希望条件</b><p>東京 / リモート可 / 事業会社</p></div>
                      <div><b>経験スキル</b><p>SaaS営業、CS、業務改善</p></div>
                      <div><b>面談メモ</b><p>成長環境と裁量を重視。選考前に業務内容を丁寧に確認したい。</p></div>
                    </div>
                  </section>
                </div>
              </div>
            </div>
          </article>

          <article class="feature-row feature-row-reverse">
            <div class="feature-copy">
              <h3>求人情報を、<span>比較しやすい形</span>で確認</h3>
              <p>職種、条件、魅力を整理し、候補者に合う求人を検討しやすくします。</p>
            </div>
            <div class="screen-card" aria-label="求人一覧・求人詳細の画面イメージ">
              <div class="app-screen job-screen">
                <div class="screen-topbar"><strong>求人</strong><span>職種</span><span>勤務地</span></div>
                <div class="job-columns">
                  <div class="job-list">
                    <p class="is-active"><b>SaaS営業</b><small>東京 / 500-700万</small></p>
                    <p><b>CS企画</b><small>東京 / 450-650万</small></p>
                    <p><b>事業開発</b><small>大阪 / 600-800万</small></p>
                  </div>
                  <div class="job-detail">
                    <strong>SaaS営業</strong>
                    <dl>
                      <div><dt>必須条件</dt><dd>法人営業3年以上、SaaS経験</dd></div>
                      <div><dt>歓迎条件</dt><dd>CS連携、営業企画経験</dd></div>
                      <div><dt>魅力</dt><dd>裁量のある提案活動、リモート併用</dd></div>
                    </dl>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="feature-row">
            <div class="feature-copy">
              <h3><span>CRM / CSVデータを取り込み、</span>項目を整理</h3>
              <p>バラバラな項目や表記ゆれを整え、提案業務に使えるデータへ変換します。</p>
            </div>
            <div class="screen-card" aria-label="データ取込・マッピング画面の画面イメージ">
              <div class="app-screen import-screen">
                <div class="screen-topbar"><strong>データ取込</strong><span>CSV</span><span>CRM</span></div>
                <div class="mapping-flow">
                  <div>
                    <b>取込データ</b>
                    <p>希望勤務地</p>
                    <p>経験職種</p>
                    <p>年収希望</p>
                  </div>
                  <div class="mapping-arrow">整理</div>
                  <div>
                    <b>omJob match項目</b>
                    <p>勤務地</p>
                    <p>経験スキル</p>
                    <p>希望年収</p>
                  </div>
                </div>
                <div class="normalize-bar"><span></span><strong>表記ゆれを確認中</strong></div>
              </div>
            </div>
          </article>

          <article class="feature-row feature-row-reverse">
            <div class="feature-copy">
              <h3><span>提案前の確認作業を</span>スムーズに</h3>
              <p>提案理由や確認ポイントを整理し、提案前の不安や抜け漏れを減らします。</p>
            </div>
            <div class="screen-card" aria-label="提案準備画面の画面イメージ">
              <div class="app-screen proposal-screen">
                <div class="screen-topbar"><strong>提案準備</strong><span>理由</span><span>確認</span></div>
                <div class="proposal-grid">
                  <div><b>候補者</b><p>希望条件・経験・温度感を整理済み</p></div>
                  <div><b>求人</b><p>要件・魅力・注意点を整理済み</p></div>
                  <div class="proposal-reason"><b>提案理由</b><p>営業経験とSaaS志向が一致。裁量ある環境を重視する希望にも合う。</p></div>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section class="section outcomes" aria-labelledby="outcomes-title">
        <div class="outcome-face-effect" aria-hidden="true">
          <svg viewBox="0 0 620 620">
            <defs>
              <radialGradient id="outcome-face-gradient" cx="42%" cy="38%" r="68%">
                <stop offset="0%" stop-color="#5c86ff" stop-opacity="0.14"></stop>
                <stop offset="58%" stop-color="#0038e5" stop-opacity="0.08"></stop>
                <stop offset="100%" stop-color="#0038e5" stop-opacity="0.03"></stop>
              </radialGradient>
            </defs>
            <circle class="outcome-face-fill" cx="310" cy="310" r="300"></circle>
            <path class="outcome-face-smile" d="M172 318c52 108 224 108 276 0"></path>
          </svg>
        </div>
        <div class="section-heading">
          <p class="eyebrow">OmJob Matchで変わる、CAの求人提案業務。</p>
          <h2 id="outcomes-title" class="reveal-heading">
            <span>求人提案の準備が、<span class="heading-accent">チームで再現できる業務</span>へ。</span>
          </h2>
          <p>
            候補者情報と求人情報が整理されることで、CAが迷わず提案準備に進みやすくなり、組織として提案品質を高めやすくなります。
          </p>
        </div>
        <div class="outcome-grid" aria-label="OmJob Matchで変わる、CAの求人提案業務。">
          <article>
            <span class="outcome-number">01</span>
            <span class="outcome-label">流れが揃う</span>
            <h3>提案準備の流れが見えるようになる</h3>
            <p>候補者情報、求人情報、提案理由が一つの流れで整理され、誰が見ても提案準備の状態を把握しやすくなります。</p>
          </article>
          <article>
            <span class="outcome-number">02</span>
            <span class="outcome-label">自信を持てる</span>
            <h3>CAごとのばらつきを減らしやすくなる</h3>
            <p>経験や記憶だけに頼らず、確認すべき情報や提案理由を揃えやすくなります。</p>
          </article>
          <article>
            <span class="outcome-number">03</span>
            <span class="outcome-label">型が残る</span>
            <h3>新人育成や業務改善につなげやすくなる</h3>
            <p>どの情報を見て、なぜその求人を選んだのかが残るため、提案の振り返りや育成に活用しやすくなります。</p>
          </article>
        </div>
      </section>

      <section class="mid-cta" aria-labelledby="mid-cta-title">
        <div>
          <p class="eyebrow">Download</p>
          <h2 id="mid-cta-title" class="reveal-heading">
            <span>OmJob Matchを使用した提案業務の変化を、資料で確認できます。</span>
          </h2>
          <p>候補者・求人データをどのように整理し、提案準備へ活用できるのかをご紹介しています。</p>
        </div>
        <a class="button button-download" href="#cta" data-intent-link="download">サービス資料をダウンロード</a>
      </section>

      <section class="final-cta" id="cta" aria-labelledby="cta-title">
        <div class="cta-copy">
          <p class="eyebrow">Next Step</p>
          <h2 id="cta-title" class="cta-title-line reveal-heading">
            <span>
              <span class="title-line">CAが迷わず提案に進める状態を、</span>
              <span class="title-line">組織でつくる。</span>
            </span>
          </h2>
          <p>
            サービス資料のダウンロード、または導入や活用イメージのご相談は、以下からお問い合わせください。
          </p>
        </div>
        <form class="lead-form" data-lead-form>
          <fieldset class="intent-field">
            <legend>ご希望の内容</legend>
            <label>
              <input type="radio" name="intent" value="download" checked>
              <span>
                <strong>サービス資料</strong>
                <small>まずは内容を確認する</small>
              </span>
            </label>
            <label>
              <input type="radio" name="intent" value="consult">
              <span>
                <strong>相談してみる</strong>
                <small>導入や連携について話す</small>
              </span>
            </label>
          </fieldset>
          <label>
            会社名
            <input name="company" type="text" autocomplete="organization" required>
          </label>
          <label>
            お名前
            <input name="name" type="text" autocomplete="name" required>
          </label>
          <label>
            メールアドレス
            <input name="email" type="email" autocomplete="email" required>
          </label>
          <button class="button button-primary" type="submit">送信内容を確認</button>
          <p class="form-message" role="status" aria-live="polite" data-form-message></p>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <a class="logo-link" href="#top" aria-label="omJob match トップへ">
        <img src={`${basePath}assets/omjob-logo.png`} alt="omJob match" width="168" height="106">
      </a>
      <p>© 2026 omJob match</p>
    </footer>

    <script src="../scripts/main.js"></script>
  </body>
</html>
